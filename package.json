{
  "name": "text-please",
  "version": "0.0.1",
  "description": "Extract plain text from pdf, docx, xlsx, ... ",
  "keywords": [
    "extract",
    "rag",
    "plain-text",
    "pdf",
    "docx",
    "xlsx"
  ],
  "homepage": "https://github.com/Thomascogez/text-please#readme",
  "bugs": {
    "url": "https://github.com/Thomascogez/text-please/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Thomascogez/text-please.git"
  },
  "license": "ISC",
  "author": "Thomas cogez",
  "type": "module",
  "main": "./dist/node/index.js",
  "types": "./dist/node/index.d.ts",
  "exports": {
    "./node": {
      "import": "./dist/node/index.js",
      "types": "./dist/node/index.d.ts"
    },
    "./node/module.wasm": {
      "import": "./dist/node/index_bg.wasm",
      "types": "./dist/node/index_bg.wasm.d.ts"
    },
    "./web": {
      "import": "./dist/web/index.js",
      "types": "./dist/web/index.d.ts"
    },
    "./web/module.wasm": {
      "import": "./dist/web/index_bg.wasm",
      "types": "./dist/web/index_bg.wasm.d.ts"
    },
    "./cf": {
      "import": "./dist/web/index.js",
      "types": "./dist/web/index.d.ts"
    },
    "./cf/module.wasm": {
      "import": "./dist/web/index_bg.wasm",
      "types": "./dist/web/index_bg.wasm.d.ts"
    }
  },
  "scripts": {
    "build:node": "wasm-pack build --no-pack --out-dir ./dist/node --target nodejs --out-name index && rm -rf dist/node/.gitignore",
    "build:web": "wasm-pack build --no-pack --out-dir ./dist/web --target web --out-name index && rm -rf dist/web/.gitignore",
    "build": "pnpm run \"/^build:.*/\"",
    "changeset": "pnpx @changesets/cli"
  },
  "files": [
    "dist"
  ],
  "packageManager": "pnpm@11.0.0-dev.1005+sha512.91f84a392eea348ea4852a182912d2520273a4336f933b78cc44bc931eb999923c097e9433a9b355adc1f725725ea99082fc9f032a559df832632e764c92c798"
}